{
  "name": "@nexuscrm/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "db:generate": "typeorm-ts-node-commonjs migration:generate src/database/migrations/schema-change -d src/database/data-source.ts",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "db:migrate:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "db:migrate:show": "typeorm-ts-node-commonjs migration:show -d src/database/data-source.ts",
    "db:seed": "tsx src/database/seeds/seed-runner.ts",
    "db:seed:reset": "tsx src/database/seeds/seed-runner.ts --reset"
  },
  "dependencies": {
    "@casl/ability": "6.8.1",
    "@faker-js/faker": "10.5.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/typeorm": "11.0.3",
    "argon2": "0.44.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "dotenv": "17.4.2",
    "jsonwebtoken": "9.0.3",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "swagger-ui-express": "5.0.1",
    "typeorm": "0.3.30",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.28",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "ts-node": "10.9.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
