{
  "name": "@nexuscrm/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "lint": "echo \"TODO: configure ESLint for API\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/database/seeds/seed-runner.ts",
    "db:seed:reset": "tsx src/database/seeds/seed-runner.ts --reset"
  },
  "dependencies": {
    "@casl/ability": "6.8.1",
    "@faker-js/faker": "10.5.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "argon2": "0.44.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "jsonwebtoken": "9.0.3",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "swagger-ui-express": "5.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.28",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "drizzle-kit": "0.31.10",
    "ts-node": "10.9.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
