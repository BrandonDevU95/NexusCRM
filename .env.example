# Environment
NODE_ENV=development

# Docker Compose
COMPOSE_PROJECT_NAME=nexuscrm

# PostgreSQL (Docker)
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_CONTAINER_NAME=nexuscrm-postgres
POSTGRES_USER=nexuscrm
POSTGRES_PASSWORD=replace-with-a-local-postgres-password
POSTGRES_DB=nexuscrm
POSTGRES_PORT=5432

# pgAdmin (Docker)
PGADMIN_IMAGE=dpage/pgadmin4:latest
PGADMIN_CONTAINER_NAME=nexuscrm-pgadmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@nexuscrm.dev
PGADMIN_DEFAULT_PASSWORD=replace-with-a-local-pgadmin-password
PGADMIN_CONFIG_SERVER_MODE=False
PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED=False

# API
API_PORT=3001
API_GLOBAL_PREFIX=api/v1
WEB_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://nexuscrm:replace-with-a-local-postgres-password@localhost:5432/nexuscrm

# Auth foundation placeholders; replace before real auth implementation.
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=false

# Seeds
SEED_FAKER_SEED=20260709
ALLOW_DB_RESET=false
